html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    width: 100%;
    overflow: hidden;
    background: white;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    cursor: pointer;
    user-select: none;
    -webkit-user-select: none;
}

body {
    display: grid;
    place-items: center;
}

#k-letter {
    font-size: max(48px, 10vh);
    line-height: 1;
    color: black;
}
